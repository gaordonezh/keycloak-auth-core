{
  "name": "keycloak-auth-core",
  "private": true,
  "version": "1.1.1",
  "description": "Librería de autenticación con Keycloak para React",
  "type": "module",
  "main": "./dist/auth-library.cjs.js",
  "module": "./dist/auth-library.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/auth-library.es.js",
      "require": "./dist/auth-library.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/keycloak-auth-core.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20",
    "axios": ">=1 <2",
    "keycloak-js": ">=26 <27"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaordonezh/keycloak-auth-core.git"
  }
}
